<!DOCTYPE html>
<html lang="ar" dir="rtl">
<%- include('partials/head', { title: 'الملف الشخصي' }) %>
<body>
    <%- include('partials/header') %>
    
    <main class="main-content">
        <section id="profile" class="section active">
            <h2 class="section-title">الملف الشخصي</h2>
            <div class="profile-container" style="background: white; border-radius: 20px; padding: 30px; box-shadow: 0 5px 20px rgba(0,0,0,0.05);">
                <div class="profile-header" style="text-align: center; margin-bottom: 30px;">
                    <img id="profileImage" src="<%= user.photoURL || '/public/images/user-placeholder.png' %>" style="width: 100px; height: 100px; border-radius: 50%; margin-bottom: 15px; border: 3px solid var(--secondary-color); padding: 5px;">
                    <h3 id="profileName"><%= user.displayName || 'مستخدم' %></h3>
                    <p id="profileEmail" style="color: #888;"><%= user.email %></p>
                </div>
                <div class="profile-details">
                    <div class="detail-item" style="margin-bottom: 15px; display: flex; justify-content: space-between; border-bottom: 1px solid #eee; padding-bottom: 10px;">
                        <strong>الاسم:</strong> <span id="detailName"><%= user.displayName || 'غير محدد' %></span>
                    </div>
                    <div class="detail-item" style="margin-bottom: 15px; display: flex; justify-content: space-between; border-bottom: 1px solid #eee; padding-bottom: 10px;">
                        <strong>الهاتف:</strong> <span id="detailPhone">جاري التحميل...</span>
                    </div>
                    <div class="detail-item" style="margin-bottom: 15px; display: flex; justify-content: space-between; border-bottom: 1px solid #eee; padding-bottom: 10px;">
                        <strong>العنوان:</strong> <span id="detailAddress">جاري التحميل...</span>
                    </div>
                </div>
                <button id="editProfileBtn" class="btn-primary" style="width: 100%; margin-top: 20px;">تعديل الملف الشخصي</button>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
